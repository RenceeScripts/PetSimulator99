Section:NewButton("Auto Buy Lucky Dices", "ButtonInfo", function()
    local function buyLuckyDice(diceNumber)
        local args = {
            [1] = "LuckyDiceMerchant",
            [2] = diceNumber
        }
        local success, err = pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Network"):WaitForChild("Merchant_RequestPurchase"):InvokeServer(unpack(args))
        end)
        if not success then
            warn("Failed to buy Lucky Dice with number " .. diceNumber .. ": " .. tostring(err))
        end
    end

    while true do
        for diceNumber = 1, 6 do
            buyLuckyDice(diceNumber)
            wait(0.1) -- Adjust the wait time as needed to match the purchasing speed
        end
        print("Clicked")
    end
end)

local craftingStates = {
    ["Lucky Dice II"] = false,
    ["Lucky Dice III"] = false,
    ["Mega Lucky Dice"] = false,
    ["Mega Lucky Dice II"] = false
}

-- Function to craft Lucky Dice
local function craftLuckyDice(diceType)
    local args = {
        [1] = diceType,
        [2] = 1
    }
    local success, err = pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Network"):WaitForChild("LuckyDice_Craft"):InvokeServer(unpack(args))
    end)
    if not success then
        warn("Failed to craft " .. diceType .. ": " .. tostring(err))
    end
end

-- Toggle function
local function toggleCrafting(diceType, state)
    craftingStates[diceType] = state
    if state then
        while craftingStates[diceType] do
            craftLuckyDice(diceType)
            wait(0.1) -- Adjust the wait time as needed to control crafting speed
        end
    end
end

