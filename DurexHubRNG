local upgrades = { "RNGEggLuck", "RNGHatchSpeed", "RNGBonusLuck", "RNGExtraEggs" }
local currentIndex = 1

local function purchaseUpgrade(upgradeType)
    local args = {
        [1] = "First",
        [2] = upgradeType
    }
    
    game:GetService("ReplicatedStorage").Network.Rng_PurchaseUpgrade:InvokeServer(unpack(args))
end

local function autoUpgrade()
    while true do
        purchaseUpgrade(upgrades[currentIndex])
        wait(1)  -- Adjust the interval for purchasing upgrades
        
        currentIndex = currentIndex % #upgrades + 1
    end
end

Section:NewToggle("Auto Upgrade RNG", "Toggle auto upgrading", function(state)
    if state then
        autoUpgrade()
    end
end)
